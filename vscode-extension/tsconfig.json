{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@designdead/canvas": ["../src/app/components/canvas"],
      "@designdead/canvas/*": ["../src/app/components/canvas/*"]
    }
  },
  "include": ["src", "../src/app/components/canvas"],
  "exclude": ["dist", "node_modules"]
}
