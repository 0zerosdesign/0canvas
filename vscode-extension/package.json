{
  "name": "designdead-vscode",
  "displayName": "DesignDead",
  "description": "Visual editor for DesignDead .dd project files — preview variants, manage feedback, and edit design tokens.",
  "version": "0.1.0",
  "publisher": "zerosdesign",
  "license": "MIT",

  "repository": {
    "type": "git",
    "url": "https://github.com/withso/design-dead.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": ["Other", "Visualization"],
  "keywords": ["designdead", "design", "visual-editor", "custom-editor", "dd", "variants", "css", "html"],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "extensionKind": ["workspace"],
  "capabilities": {
    "untrustedWorkspaces": { "supported": true },
    "virtualWorkspaces": { "supported": true }
  },
  "contributes": {
    "commands": [
      {
        "command": "designdead.openAsText",
        "title": "Open as Text",
        "category": "DesignDead",
        "icon": "$(json)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "designdead.openAsText",
          "when": "resourceExtname == .dd && activeCustomEditorId == designdead.editor",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "designdead.openAsText",
          "when": "resourceExtname == .dd",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "designdead.editor",
        "displayName": "DesignDead Visual Editor",
        "selector": [{ "filenamePattern": "*.dd" }],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "DesignDead",
      "properties": {
        "designdead.preview.defaultZoom": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 2,
          "description": "Default preview zoom for variant cards."
        },
        "designdead.editor.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "maximum": 2000,
          "description": "Debounce delay (ms) before webview edits are written back to the .dd file."
        }
      }
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:host": "tsup",
    "build:webview": "vite build --config vite.webview.config.ts",
    "build": "pnpm run clean && pnpm run build:host && pnpm run build:webview",
    "watch:host": "tsup --watch",
    "watch:webview": "vite build --watch --config vite.webview.config.ts",
    "dev": "pnpm run build:host && pnpm run build:webview",
    "vscode:prepublish": "pnpm run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {},
  "devDependencies": {
    "@xyflow/react": "^12.10.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.86.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "lucide-react": "^0.400.0",
    "vite": "^6.0.0"
  }
}
