67; --demo-primary: #216869; --demo-primary-strong: #184e4f; --demo-primary-soft: #dcefee; --demo-accent: #c1784a; --demo-success: #3a7d5d; --demo-warning: #b97a24; --demo-danger: #c05a3d; --demo-shadow-sm: 0 10px 30px rgba(121, 95, 63, 0.08); --demo-shadow-lg: 0 22px 60px rgba(121, 95, 63, 0.14); --blue-300: #8fc4c2; --blue-400: #68abaa; --blue-500: #4f9492; --blue-700: #216869; --color--surface--floor: #f2ebdf; --color--surface--0: var(--demo-surface-strong); --color--surface--1: var(--demo-surface); --color--surface--2: var(--demo-surface-muted); --color--surface--absolute: #ffffff; --color--surface--inverted: #1f2a24; --color--text--on-surface: var(--demo-text); --color--text--on-surface-variant: #3c4842; --color--text--muted: var(--demo-text-muted); --color--text--disabled: #93a097; --color--text--hint: #7f8b83; --color--text--on-primary: #f9fbfb; --color--text--on-success: #f4fbf7; --color--text--on-critical: #fff6f2; --color--text--on-warning: #fffaf1; --color--text--primary: var(--demo-primary); --color--text--primary-light: #3b8d89; --color--text--link: var(--demo-primary); --color--text--link-hover: var(--demo-primary-strong); --color--text--info: #3b8d89; --color--text--success: var(--demo-success); --color--text--warning: var(--demo-warning); --color--text--critical: var(--demo-danger); --color--text--critical-light: #d2755b; --color--border--on-surface-0: var(--demo-border); --color--border--on-surface-1: var(--demo-border-strong); --color--border--on-surface-2: rgba(102, 84, 61, 0.4); --color--base--primary: var(--demo-primary); --color--base--primary-hover: var(--demo-primary-strong); --color--base--primary-light: #3b8d89; --color--status--info: #4f9492; --color--status--success: var(--demo-success); --color--status--warning: var(--demo-warning); --color--status--critical: var(--demo-danger); --color--status--connecting: var(--demo-accent); }\n@layer base {\n  * { box-sizing: border-box; }\n  html { font-size: 15px; scroll-behavior: smooth; }\n  body { min-height: 100vh; margin: 0px; font-family: var(--font-sans); color: var(--demo-text); background: radial-gradient(circle at top left, rgba(193, 120, 74, 0.12), transparent 28%), radial-gradient(circle at top right, rgba(33, 104, 105, 0.14), transparent 26%), linear-gradient(180deg, var(--demo-bg-soft), var(--demo-bg)); -webkit-font-smoothing: antialiased; }\n  ::selection { background: rgba(33, 104, 105, 0.18); color: var(--demo-primary-strong); }\n  a { color: inherit; text-decoration: none; }\n  button, input, textarea, select { font: inherit; }\n}\n@layer components {\n  .demo-page { position: relative; isolation: isolate; }\n  .demo-card { position: relative; border: 1px solid var(--demo-border); border-radius: 1.5rem; background: var(--demo-surface); box-shadow: var(--demo-shadow-sm); backdrop-filter: blur(18px); transition: transform 220ms, box-shadow 220ms, border-color 220ms, background-color 220ms; }\n  .demo-card:hover { transform: translateY(-2px); border-color: var(--demo-border-strong); box-shadow: var(--demo-shadow-lg); }\n  .demo-soft-card { background: rgba(255, 249, 241, 0.72); }\n  .demo-badge { display: inline-flex; align-items: center; gap: 0.45rem; border: 1px solid var(--demo-border); border-radius: 999px; background: rgba(255, 255, 255, 0.76); padding: 0.45rem 0.85rem; font-size: 0.76rem; font-weight: 700; letter-spacing: 0.01em; color: var(--demo-text-muted); }\n  .demo-badge-primary { border-color: rgba(33, 104, 105, 0.2); background: var(--demo-primary-soft); color: var(--demo-primary-strong); }\n  .demo-badge-success { border-color: rgba(58, 125, 93, 0.2); background: rgba(58, 125, 93, 0.1); color: var(--demo-success); }\n  .demo-badge-warning { border-color: rgba(185, 122, 36, 0.2); background: rgba(185, 122, 36, 0.1); color: var(--demo-warning); }\n  .demo-link { color: var(--demo-primary); transition: color 180ms; }\n  .demo-link:hover { color: var(--demo-primary-strong); }\n  .demo-inline-code { display: inline-flex; align-items: center; border-radius: 0.6rem; background: rgb(243, 236, 224); padding: 0.12rem 0.38rem; font-family: var(--font-mono); font-size: 0.9em; color: var(--demo-primary-strong); }\n  .demo-code-shell { position: relative; overflow: hidden; border: 1px solid var(--demo-border); border-radius: 1.4rem; background: rgb(248, 242, 232); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8), var(--demo-shadow-sm); }\n  .demo-code-shell::before { content: \"\"; position: absolute; inset: 0px; pointer-events: none; background: linear-gradient(rgba(255, 255, 255, 0.32), transparent 40%); }\n  .demo-code-label { display: inline-flex; align-items: center; border-radius: 999px; background: rgba(255, 255, 255, 0.72); padding: 0.32rem 0.65rem; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--demo-text-muted); }\n  .demo-icon-button { display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--demo-border); border-radius: 0.9rem; background: rgba(255, 255, 255, 0.8); color: var(--demo-text-muted); box-shadow: rgba(121, 95, 63, 0.08) 0px 8px 20px; transition: transform 180ms, border-color 180ms, color 180ms, background-color 180ms; }\n  .demo-icon-button:hover { transform: translateY(-1px) scale(1.02); border-color: var(--demo-border-strong); background: rgb(255, 255, 255); color: var(--demo-text); }\n  .demo-primary-button { display: inline-flex; align-items: center; justify-content: center; gap: 0.55rem; border: 1px solid transparent; border-radius: 1rem; background: var(--demo-primary); padding: 0.85rem 1.2rem; color: rgb(255, 255, 255); font-weight: 700; box-shadow: rgba(33, 104, 105, 0.2) 0px 14px 28px; transition: transform 180ms, box-shadow 180ms, background-color 180ms; }\n  .demo-primary-button:hover { transform: translateY(-1px); background: var(--demo-primary-strong); box-shadow: rgba(33, 104, 105, 0.24) 0px 18px 30px; }\n  .demo-secondary-button { display: inline-flex; align-items: center; justify-content: center; gap: 0.55rem; border: 1px solid var(--demo-border); border-radius: 1rem; background: rgba(255, 255, 255, 0.74); padding: 0.85rem 1.2rem; color: var(--demo-text); font-weight: 700; transition: transform 180ms, border-color 180ms, background-color 180ms; }\n  .demo-secondary-button:hover { transform: translateY(-1px); border-color: var(--demo-border-strong); background: rgba(255, 255, 255, 0.92); }\n  .demo-kbd { display: inline-flex; align-items: center; border: 1px solid var(--demo-border); border-radius: 0.7rem; background: rgba(255, 255, 255, 0.74); padding: 0.18rem 0.52rem; font-family: var(--font-mono); font-size: 0.78rem; color: var(--demo-text); }\n  .demo-divider { height: 1px; background: linear-gradient(90deg, transparent, var(--demo-border-strong), transparent); }\n  .demo-grid-accent { position: absolute; inset: 1rem; z-index: 0; border-radius: 1.4rem; background-image: linear-gradient(rgba(102, 84, 61, 0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(102, 84, 61, 0.06) 1px, transparent 1px); background-size: 22px 22px; opacity: 0.6; mask-image: radial-gradient(circle, black 45%, transparent 100%); pointer-events: none; }\n  .demo-orb { width: 4.75rem; height: 4.75rem; border-radius: 999px; background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.8), transparent 30%), linear-gradient(135deg, rgba(193, 120, 74, 0.4), rgba(33, 104, 105, 0.78)); box-shadow: rgba(255, 255, 255, 0.5) 0px 1px 0px inset, rgba(33, 104, 105, 0.18) 0px 16px 38px; }\n  .demo-table { width: 100%; border-collapse: collapse; }\n  .demo-table th, .demo-table td { padding: 0.9rem 1rem; border-bottom: 1px solid var(--demo-border); font-size: 0.84rem; text-align: left; vertical-align: top; }\n  .demo-table th { color: var(--demo-text-muted); font-weight: 700; }\n  .demo-table tbody tr { transition: background-color 180ms; }\n  .demo-table tbody tr:hover { background: rgba(255, 255, 255, 0.52); }\n  .demo-table tbody tr:last-child td { border-bottom: n