# 0research — Environment Variables Template
# Copy to .env and fill in actual values

# Directus CMS (Railway)
DIRECTUS_URL=https://cms.0research.zeros.design
DIRECTUS_ADMIN_TOKEN=

# Cloudflare R2 (media storage)
R2_PUBLIC_URL=https://your-media-domain.example.com

# Supabase (0research project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Webhook secret (Directus → Supabase Edge Function sync)
WEBHOOK_SECRET=

# Vite (exposed to frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
