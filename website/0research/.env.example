# ============================================
# 0research — environment variables
# ============================================
# Copy to .env.local (gitignored) to override defaults in local dev.
# Production uses the committed defaults (empty VITE_* → auth-client
# falls back to accounts.zeros.design / accounts-api.zeros.design).

# --- Auth endpoints (override for local dev) ---
# Local 0accounts frontend (for sign-in redirect)
VITE_ACCOUNTS_LOGIN_URL=http://localhost:3001/login

# Local 0accounts backend API
VITE_ACCOUNTS_API_URL=http://localhost:4456/api/v1
