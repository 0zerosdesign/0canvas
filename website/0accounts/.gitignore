# Dependencies
node_modules/

# Build output
dist/
build/

# Environment variables — ignore at any depth so packages/*/env files
# don't leak into commits. `.env.example` / `.env.sample` templates are
# explicitly allowed back in.
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
!**/.env.example
!**/.env.sample

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
npm-debug.log*

# TypeScript cache
*.tsbuildinfo

# Vite
vite.config.ts.timestamp-*
