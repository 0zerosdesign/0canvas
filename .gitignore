# Dependencies
node_modules/
.pnpm-debug.log*

# Build output
dist/
dist-engine/
dist-electron/
release/
binaries/
/lib/
*.tgz
out/
*.tsbuildinfo

# Tauri Rust build output
src-tauri/target/
src-tauri/gen/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local

# apps/ — sibling apps vendored in this repo (0colors, …)
# Generated outputs, deps, logs, and env files under apps/ are never tracked.
apps/*/node_modules/
apps/**/node_modules/
apps/*/dist/
apps/**/dist/
apps/*/build/
apps/**/build/
apps/**/.cache/
apps/**/*.log
apps/**/.env
apps/**/.env.local
apps/**/.env.*.local
apps/**/.env.production

# Tauri updater signing key — PRIVATE, never commit
src-tauri/tauri-updater.key

# Testing
coverage/
.nyc_output

# Temporary files
.tmp/
temp/

# Zeros engine (generated at runtime)
.zeros/
.mcp.json

# Testing harness (local only)
testing/

# Publish workflow temp files
package.figma.json
package.figmamake.json
*.bun-build

# Visual harness output (local captures)
snapshots/current/
snapshots/diff/

# website/ — sibling frontends vendored for Cloudflare Pages deploy (0research, 0accounts, …)
# Same pattern as apps/: env + node_modules + dist + build + logs + Dataaset training never tracked.
website/*/node_modules/
website/**/node_modules/
website/*/dist/
website/**/dist/
website/*/build/
website/**/build/
website/**/.cache/
website/**/*.log
website/**/.env
website/**/.env.local
website/**/.env.*.local
website/**/.env.production
website/*/tmp/
website/**/tmp/
# Dataaset training corpora are multi-GB user data; never tracked
website/**/Dataaset training/

# servers/ — backend services vendored for Railway deploy (0research, 0accounts, …)
# Same pattern as website/: env + node_modules + build/dist + logs never tracked.
servers/*/node_modules/
servers/**/node_modules/
servers/*/dist/
servers/**/dist/
servers/*/build/
servers/**/build/
servers/**/*.log
servers/**/.env
servers/**/.env.local
servers/**/.env.*.local
servers/**/.env.production
