a-section { text-align: center; padding: 100px 24px; background: linear-gradient(transparent, rgba(59, 130, 246, 0.04) 50%, transparent); }\n.cta-title { font-size: 36px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 12px; }\n.cta-subtitle { font-size: 16px; color: var(--text-muted); margin-bottom: 32px; }\n.footer { border-top: 1px solid var(--border); padding: 60px 0px 32px; }\n.footer-inner { max-width: 1200px; margin: 0px auto; padding: 0px 24px; }\n.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 48px; }\n.footer-tagline { font-size: 14px; color: var(--text-muted); margin-top: 12px; max-width: 240px; }\n.footer-col { display: flex; flex-direction: column; gap: 10px; }\n.footer-col-title { font-size: 13px; font-weight: 600; margin-bottom: 4px; }\n.footer-link { font-size: 13px; color: var(--text-muted); transition: color 0.2s; }\n.footer-link:hover { color: var(--text); }\n.footer-bottom { border-top: 1px solid var(--border); padding-top: 24px; font-size: 13px; color: var(--text-muted); }\n@media (max-width: 768px) {\n  .nav-links { display: none; }\n  .stats-grid { grid-template-columns: repeat(2, 1fr); }\n  .features-grid { grid-template-columns: 1fr; }\n  .testimonials-grid { grid-template-columns: 1fr; }\n  .pricing-grid { grid-template-columns: 1fr; }\n  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }\n}\n[data-designdead-root] { --dd-bg: #000000; --dd-fg: #ededed; --dd-card: #0a0a0a; --dd-muted: #111111; --dd-muted-fg: #888888; --dd-border: #222222; --dd-ring: #333333; }\n[data-designdead-root] { -webkit-font-smoothing: antialiased; text-size-adjust: 100%; font-family: \"Geist Sans\", Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif !important; font-size: 14px !important; line-height: 1.5 !important; color: var(--dd-fg) !important; letter-spacing: normal !important; font-weight: 400 !important; text-transform: none !important; font-style: normal !important; 