{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "0canvas",
  "version": "0.1.0",
  "identifier": "design.zeros.oCanvas",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:ui",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "0canvas",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "externalBin": ["binaries/0canvas-engine"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "copyright": "© 2026 Zeros Design",
    "category": "DeveloperTool",
    "shortDescription": "Visual design tool for production code",
    "longDescription": "0canvas is a design-first Mac app that lets designers and solo developers edit production React + Tailwind code visually, with git, an embedded terminal, and AI agent integration."
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["zero-canvas"]
      }
    }
  }
}
