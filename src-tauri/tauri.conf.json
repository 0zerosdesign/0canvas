{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zeros",
  "version": "0.1.0",
  "identifier": "design.zeros.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:ui",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zeros",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "externalBin": ["binaries/zeros-engine"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "copyright": "© 2026 Zeros Design",
    "category": "DeveloperTool",
    "shortDescription": "Visual design tool for production code",
    "longDescription": "Zeros is a design-first Mac app that lets designers and solo developers edit production React + Tailwind code visually, with git, an embedded terminal, and AI agent integration."
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["zeros"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3ODRFQTRCNENEQ0U2MUEKUldRYTV0eE1TK3FFUjB1d0hmcGg4N3AvTTlWYTRpN2JBSkk3bkZwWlVTN015UWRuNXN5cHVKckcK",
      "endpoints": [
        "https://github.com/Withso/zeros/releases/latest/download/latest.json"
      ]
    }
  }
}
