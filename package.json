{
  "name": "@withso/zeros",
  "version": "0.0.5",
  "private": true,
  "description": "Zeros — Visual design tool for production code. Mac app (Electron). Inspect elements, edit styles, push to git.",
  "license": "MIT",
  "main": "dist-electron/main.cjs",
  "electronmon": {
    "patterns": [
      "dist-electron/**/*"
    ]
  },
  "scripts": {
    "build:engine": "tsup",
    "watch:engine": "tsup --watch",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "dev": "vite",
    "test:ui": "vite",
    "build:ui": "vite build",
    "serve:engine": "node dist-engine/cli.js",
    "electron:compile": "tsup --config electron/tsup.config.ts",
    "electron:compile:watch": "tsup --config electron/tsup.config.ts --watch",
    "electron:dev": "concurrently -k -n vite,main,engine,app -c cyan,magenta,yellow,green \"pnpm dev\" \"tsup --config electron/tsup.config.ts --watch\" \"tsup --watch\" \"wait-on http://localhost:5173 dist-electron/main.cjs dist-engine/cli.js && env -u ELECTRON_RUN_AS_NODE electronmon .\"",
    "electron:rebuild": "electron-rebuild --only node-pty,keytar",
    "electron:build": "pnpm build:sidecar && pnpm electron:compile && pnpm build:ui && electron-builder --config electron-builder.yml",
    "check:ui": "node scripts/check-ui-consistency.mjs",
    "snap:ui": "node scripts/visual-harness.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.0",
    "electron-updater": "^6.8.3",
    "idb": "^8.0.3",
    "keytar": "^7.9.0",
    "lucide-react": "^0.400.0",
    "node-pty": "^1.1.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.14.0",
    "simple-git": "^3.36.0",
    "tailwind-merge": "^3.0.0",
    "tinyglobby": "^0.2.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.5"
  },
  "keywords": [
    "design",
    "mac-app",
    "electron",
    "inspector",
    "ai",
    "agent",
    "visual",
    "css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Withso/zeros.git"
  },
  "homepage": "https://github.com/Withso/zeros#readme",
  "bugs": {
    "url": "https://github.com/Withso/zeros/issues"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "esbuild",
      "keytar",
      "node-pty"
    ]
  }
}
