{
  "name": "@withso/zeros",
  "version": "0.0.5",
  "private": true,
  "description": "Zeros — Visual design tool for production code. Mac app (Tauri). Inspect elements, edit styles, push to git.",
  "license": "MIT",
  "scripts": {
    "build:engine": "tsup",
    "watch:engine": "tsup --watch",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "dev": "vite",
    "test:ui": "vite",
    "build:ui": "vite build",
    "serve:engine": "node dist-engine/cli.js",
    "tauri": "tauri",
    "tauri:dev": "pnpm build:sidecar && tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "pnpm build:sidecar && pnpm build:ui && tauri build",
    "check:ui": "node scripts/check-ui-consistency.mjs",
    "snap:ui": "node scripts/visual-harness.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@parcel/watcher": "^2.5.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.1.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.400.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.14.0",
    "tailwind-merge": "^3.0.0",
    "tauri-pty": "^0.2.1",
    "tinyglobby": "^0.2.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "keywords": [
    "design",
    "mac-app",
    "tauri",
    "inspector",
    "ai",
    "agent",
    "visual",
    "css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Withso/zeros.git"
  },
  "homepage": "https://github.com/Withso/zeros#readme",
  "bugs": {
    "url": "https://github.com/Withso/zeros/issues"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  }
}
